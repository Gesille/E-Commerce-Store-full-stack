<!-- views/contact-confirmation.ejs -->
<div style="font-family: sans-serif; max-width: 600px; margin: 0 auto; padding: 24px;">
  <h2 style="background: linear-gradient(to right, #ec4899, #7c3aed); 
             -webkit-background-clip: text; 
             -webkit-text-fill-color: transparent;">
    Chef's World 🍽️
  </h2>

  <h3>Hi <%= name %>, we got your message! 👋</h3>

  <p style="color: #555;">
    Thanks for reaching out. Our team will get back to you as soon as possible.
  </p>

  <div style="background: linear-gradient(to right, #ec4899, #7c3aed); 
              padding: 1px; border-radius: 12px; margin-top: 24px;">
    <div style="background: white; border-radius: 12px; padding: 16px;">
      <p style="margin: 0; color: #555; font-size: 14px;">
        📍 Friar's Hill Road, Saint John's<br/>
        📞 +1 268 560 2433<br/>
        🕐 Mon - Sun: 9AM - 10PM
      </p>
    </div>
  </div>

  <p style="margin-top: 24px; color: #aaa; font-size: 12px;">
    Chef's World Support Team
  </p>
</div>