<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Receipt - <%= orderName %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, Helvetica, sans-serif; background: #f4f4f4; padding: 24px; }

    .receipt-wrap {
      max-width: 680px;
      margin: 0 auto;
      background: #ffffff;
      border: 1px solid #222222;
      color: #111111;
      font-size: 13px;
    }

    /* ── Header ── */
    .receipt-header {
      border-bottom: 2px solid #111111;
      padding: 16px 20px 14px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
    }
    .shop-name {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .shop-tagline {
      font-size: 10px;
      color: #555555;
      margin-top: 3px;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    .shop-contact {
      font-size: 11px;
      color: #444444;
      margin-top: 8px;
      line-height: 1.7;
    }
    .invoice-label {
      font-size: 26px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #111111;
      text-align: right;
    }
    .invoice-meta {
      margin-top: 8px;
      border: 1px solid #bbbbbb;
      font-size: 11px;
    }
    .invoice-meta table { width: 100%; border-collapse: collapse; min-width: 200px; }
    .invoice-meta th {
      background: #e0e0e0;
      border: 1px solid #bbbbbb;
      padding: 4px 12px;
      font-weight: 700;
      font-size: 10px;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .invoice-meta td {
      border: 1px solid #bbbbbb;
      padding: 5px 12px;
      text-align: center;
      font-size: 12px;
    }

    /* ── Order Info Bar ── */
    .order-info-row {
      background: #f7f7f7;
      border-bottom: 1px solid #bbbbbb;
      padding: 8px 20px;
      font-size: 11px;
      color: #444444;
      display: flex;
      gap: 32px;
    }
    .order-info-row .info-item { display: flex; flex-direction: column; }
    .order-info-row .info-label {
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #888888;
      margin-bottom: 1px;
    }
    .order-info-row .info-value { font-weight: 700; color: #111111; font-size: 12px; }

    /* ── Bill To / Order Info ── */
    .bill-order-row {
      display: flex;
      border-bottom: 1px solid #bbbbbb;
    }
    .bill-section {
      flex: 1;
      padding: 12px 20px;
      font-size: 12px;
      line-height: 1.7;
      border-right: 1px solid #bbbbbb;
    }
    .bill-section:last-child { border-right: none; }
    .section-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #888888;
      margin-bottom: 5px;
    }
    .bill-name { font-weight: 700; font-size: 13px; color: #111111; }
    .bill-detail { color: #444444; font-size: 12px; line-height: 1.6; }
    .bill-abst { margin-top: 6px; font-size: 11px; color: #555555; }

    .order-detail-table { width: 100%; border-collapse: collapse; font-size: 12px; }
    .order-detail-table td { padding: 2px 0; vertical-align: top; }
    .order-detail-table td:first-child { color: #666666; width: 80px; }
    .order-detail-table td:last-child { text-align: right; color: #111111; }

    /* ── PO / Terms Row ── */
    .po-head {
      background: #e0e0e0;
      border-top: 1px solid #bbbbbb;
      border-bottom: 1px solid #bbbbbb;
      display: flex;
    }
    .po-head-cell {
      flex: 1;
      padding: 4px 20px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      border-right: 1px solid #bbbbbb;
    }
    .po-head-cell:last-child { border-right: none; }
    .po-values-row {
      display: flex;
      border-bottom: 2px solid #111111;
    }
    .po-cell {
      flex: 1;
      padding: 6px 20px;
      border-right: 1px solid #bbbbbb;
      font-size: 12px;
      color: #111111;
    }
    .po-cell:last-child { border-right: none; }

    /* ── Items Table ── */
    .items-area { border-bottom: 1px solid #bbbbbb; min-height: 100px; }
    .items-table { width: 100%; border-collapse: collapse; }
    .items-table thead tr {
      background: #e0e0e0;
      border-top: 1px solid #bbbbbb;
      border-bottom: 1px solid #bbbbbb;
    }
    .items-table th {
      padding: 5px 20px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      text-align: left;
      color: #111111;
    }
    .items-table th.right, .items-table td.right { text-align: right; }
    .items-table td {
      padding: 7px 20px;
      font-size: 12px;
      border-bottom: 1px solid #eeeeee;
      vertical-align: top;
      color: #111111;
    }
    .items-table tbody tr:last-child td { border-bottom: none; }
    .discount-line td { color: #555555; font-style: italic; }

    /* ── Totals ── */
    .totals-section {
      border-top: 2px solid #111111;
      background: #ffffff;
    }
    .totals-table { width: 100%; border-collapse: collapse; }
    .totals-table td { padding: 5px 20px; font-size: 12px; color: #111111; }
    .totals-table td:last-child { text-align: right; }
    .totals-table .row-subtotal td { padding-top: 9px; }
    .totals-table .row-tax td { color: #444444; }
    .totals-table .row-total { border-top: 2px solid #111111; }
    .totals-table .row-total td {
      padding: 10px 20px;
      font-size: 16px;
      font-weight: 700;
    }
    .totals-table .row-paid { background: #f0f0f0; border-top: 1px solid #bbbbbb; }
    .totals-table .row-paid td { padding: 6px 20px; font-size: 12px; color: #333333; }
    .totals-table .row-change td { padding: 5px 20px 9px; font-size: 12px; color: #666666; background: #f0f0f0; }

    .payment-badge {
      display: inline-block;
      background: #111111;
      color: #ffffff;
      padding: 2px 8px;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-left: 6px;
    }

    /* ── Footer ── */
    .footer-strip {
      background: #111111;
      color: #ffffff;
      text-align: center;
      padding: 10px 20px;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .footer-strip a { color: #cccccc; text-decoration: underline; }

    @media (max-width: 480px) {
      body { padding: 8px; }
      .receipt-header { flex-direction: column; }
      .invoice-label { text-align: left; }
      .bill-order-row { flex-direction: column; }
      .bill-section { border-right: none; border-bottom: 1px solid #bbbbbb; }
      .po-head, .po-values-row { flex-direction: column; }
      .po-head-cell, .po-cell { border-right: none; border-bottom: 1px solid #bbbbbb; }
      .order-info-row { flex-wrap: wrap; gap: 12px; }
    }
  </style>
</head>
<body>
  <div class="receipt-wrap">

    <!-- ══ HEADER ══ -->
    <div class="receipt-header">
      <div>
        <% if (logoUrl) { %>
          <img src="<%= logoUrl %>" alt="<%= shopName %>" style="max-height: 48px; margin-bottom: 6px; display: block;" />
        <% } %>
        <div class="shop-name"><%= shopName %></div>
        <% if (shopTagline) { %>
          <div class="shop-tagline"><%= shopTagline %></div>
        <% } %>
        <div class="shop-contact">
          <!-- <% if (shopPhone) { %>Phone #&nbsp;&nbsp;<%= shopPhone %><% if (shopFax) { %> &nbsp;&nbsp;Fax #&nbsp;&nbsp;<%= shopFax %><% } %><br><% } %> -->
          <% if (shopEmail) { %><%= shopEmail %><br><% } %>
          <!-- <% if (shopAbst) { %>ABST # <%= shopAbst %><br><% } %> -->
          <% if (shopAddress) { %><%= shopAddress %><% } %>
        </div>
      </div>
      <div style="text-align: right; flex-shrink: 0;">
        <div class="invoice-label">Invoice</div>
        <div class="invoice-meta">
          <table>
            <tr>
              <th>Date</th>
              <th>Invoice #</th>
            </tr>
            <tr>
              <td><%= dateOrder %></td>
              <td><strong><%= orderName %></strong></td>
            </tr>
          </table>
        </div>
      </div>
    </div>

    <!-- ══ ORDER INFO BAR ══ -->
    <div class="order-info-row">
      <div class="info-item">
        <span class="info-label">Served By</span>
        <span class="info-value"><%= servedBy %></span>
      </div>
      <div class="info-item">
        <span class="info-label">Order Type</span>
        <span class="info-value"><%= orderType %></span>
      </div>
      <% if (posReference) { %>
      <div class="info-item">
        <span class="info-label">POS Ref</span>
        <span class="info-value"><%= posReference %></span>
      </div>
      <% } %>
    </div>

    <!-- ══ BILL TO / ORDER DETAILS ══ -->
    <div class="bill-order-row">
      <div class="bill-section">
        <div class="section-label">Bill To</div>
        <% if (customerName) { %>
          <div class="bill-name"><%= customerName %></div>
          <% if (customerAddress) { %>
            <div class="bill-detail"><%= customerAddress %></div>
          <% } %>
          <% if (customerAbst) { %>
            <div class="bill-abst">Cust ABST #&nbsp;&nbsp;<%= customerAbst %></div>
          <% } %>
        <% } else { %>
          <div class="bill-detail" style="color: #999;">Walk-in Customer</div>
        <% } %>
      </div>
      <div class="bill-section">
        <div class="section-label">Order Details</div>
        <table class="order-detail-table">
          <tr>
            <td>Order</td>
            <td><%= orderName %></td>
          </tr>
          <tr>
            <td>Date</td>
            <td><%= dateOrder %></td>
          </tr>
          <% if (sessionId) { %>
          <tr>
            <td>Session</td>
            <td><%= sessionId %></td>
          </tr>
          <% } %>
          <% if (configId) { %>
          <tr>
            <td>Register</td>
            <td><%= configId %></td>
          </tr>
          <% } %>
        </table>
      </div>
    </div>

    <!-- ══ PO / TERMS ══ -->
    <div class="po-head">
      <div class="po-head-cell">P.O. No</div>
      <div class="po-head-cell">Terms</div>
      <div class="po-head-cell">Project</div>
    </div>
    <div class="po-values-row">
      <div class="po-cell"><%= poNumber || '&mdash;' %></div>
      <div class="po-cell"><%= paymentTerms || '&mdash;' %></div>
      <div class="po-cell"><%= project || '' %></div>
    </div>

    <!-- ══ ITEMS ══ -->
    <div class="items-area">
      <table class="items-table">
        <thead>
          <tr>
            <th style="width: 44px;">Qty</th>
            <th>Description</th>
            <th class="right" style="width: 90px;">Price Each</th>
            <th class="right" style="width: 100px;">Amount</th>
          </tr>
        </thead>
        <tbody>
          <% lines.forEach(function(line) { %>
            <tr>
              <td><%= line.qty %></td>
              <td><%= line.name %></td>
              <td class="right"><%= line.priceUnit.toFixed(2) %></td>
              <td class="right"><%= line.priceTotal.toFixed(2) %></td>
            </tr>
            <% if (line.discount > 0) { %>
            <tr class="discount-line">
              <td></td>
              <td>Customer Discount</td>
              <td class="right">-<%= line.discount.toFixed(2) %>%</td>
              <td class="right" style="color: #aa0000;">-<%= (line.priceUnit * line.qty * line.discount / 100).toFixed(2) %></td>
            </tr>
            <% } %>
          <% }); %>
        </tbody>
      </table>
    </div>

   
    <div class="totals-section">
      <table class="totals-table">
        <tr class="row-subtotal">
          <td>Subtotal</td>
          <td>XCD <%= subtotal.toFixed(2) %></td>
        </tr>
        <tr class="row-tax">
          <td>ABST Sales Tax (17.0%)</td>
          <td>XCD <%= tax.toFixed(2) %></td>
        </tr>
        <tr class="row-total">
          <td>Total Due</td>
          <td>XCD <%= total.toFixed(2) %></td>
        </tr>
        <tr class="row-paid">
          <td>
            Amount Paid
            <span class="payment-badge"><%= paymentMethod %></span>
          </td>
          <td>XCD <%= amountPaid.toFixed(2) %></td>
        </tr>
        <tr class="row-change">
          <td>Change</td>
          <td>XCD <%= change.toFixed(2) %></td>
        </tr>
      </table>
    </div>

    <!-- ══ FOOTER ══ -->
    <div class="footer-strip">
      Thank you for your business &nbsp;&middot;&nbsp; <%= shopName %>
      <% if (shopEmail) { %> &nbsp;&middot;&nbsp; <%= shopEmail %><% } %>
      <% if (ticketUrl) { %><br><a href="<%= ticketUrl %>">View receipt online</a><% } %>
    </div>

  </div>
</body>
</html>