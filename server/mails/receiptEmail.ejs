<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Receipt – <%= orderName %></title>
  <!--[if mso]>
  <noscript>
    <xml><o:OfficeDocumentSettings><o:PixelsPerInch>96</o:PixelsPerInch></o:OfficeDocumentSettings></xml>
  </noscript>
  <![endif]-->
  <style>
    /* ── Reset ───────────────────────────────────────── */
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body, html {
      background-color: #f4f1ec;
      font-family: 'Georgia', 'Times New Roman', serif;
      color: #1a1a1a;
      -webkit-text-size-adjust: 100%;
    }

    /* ── Wrapper ─────────────────────────────────────── */
    .wrapper {
      width: 100%;
      background-color: #f4f1ec;
      padding: 40px 16px;
    }
    .container {
      max-width: 560px;
      margin: 0 auto;
      background: #fffdf8;
      border: 1px solid #e0d9ce;
      border-radius: 2px;
      overflow: hidden;
    }

    /* ── Header ──────────────────────────────────────── */
    .header {
      background-color: #1a1a1a;
      color: #f4f1ec;
      padding: 36px 40px 28px;
      text-align: center;
      position: relative;
    }
    .header::after {
      content: '';
      display: block;
      height: 3px;
      background: repeating-linear-gradient(
        90deg,
        #c9a96e 0px, #c9a96e 8px,
        transparent 8px, transparent 14px
      );
      position: absolute;
      bottom: 0; left: 0; right: 0;
    }
    .logo-img {
      max-height: 52px;
      max-width: 160px;
      display: block;
      margin: 0 auto 14px;
      object-fit: contain;
     
    }
    .logo-text {
      font-size: 22px;
      font-weight: normal;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #f4f1ec;
    }
    .tagline {
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #c9a96e;
      margin-top: 6px;
    }

    /* ── Receipt Banner ──────────────────────────────── */
    .receipt-banner {
      background: #c9a96e;
      color: #1a1a1a;
      text-align: center;
      padding: 10px 40px;
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-family: 'Georgia', serif;
    }

    /* ── Body ────────────────────────────────────────── */
    .body {
      padding: 32px 40px;
    }

    /* ── Meta grid ───────────────────────────────────── */
    .meta-grid {
      display: table;
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 28px;
      border: 1px solid #e0d9ce;
    }
    .meta-grid tr { border-bottom: 1px solid #e0d9ce; }
    .meta-grid tr:last-child { border-bottom: none; }
    .meta-grid td {
      padding: 9px 14px;
      font-size: 12.5px;
      line-height: 1.5;
      vertical-align: top;
    }
    .meta-label {
      color: #888;
      font-size: 10.5px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      white-space: nowrap;
      width: 38%;
      border-right: 1px solid #e0d9ce;
    }
    .meta-value {
      color: #1a1a1a;
      font-size: 12.5px;
    }

    /* ── Section heading ─────────────────────────────── */
    .section-heading {
      font-size: 10px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #888;
      border-bottom: 1px solid #e0d9ce;
      padding-bottom: 8px;
      margin-bottom: 0;
    }

    /* ── Items table ─────────────────────────────────── */
    .items-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 4px;
    }
    .items-table th {
      font-size: 10px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #888;
      padding: 10px 6px;
      text-align: left;
      border-bottom: 1px solid #e0d9ce;
      font-weight: normal;
    }
    .items-table th:last-child,
    .items-table td:last-child { text-align: right; }
    .items-table th.center,
    .items-table td.center { text-align: center; }
    .items-table td {
      font-size: 13px;
      padding: 11px 6px;
      border-bottom: 1px solid #f0ebe0;
      color: #1a1a1a;
      vertical-align: top;
    }
    .items-table tr:last-child td { border-bottom: none; }
    .item-name { font-size: 13px; }
    .item-discount {
      font-size: 10.5px;
      color: #c9a96e;
      margin-top: 2px;
    }

    /* ── Totals ──────────────────────────────────────── */
    .totals-block {
      border-top: 1px solid #e0d9ce;
      padding-top: 14px;
      margin-top: 8px;
    }
    .totals-row {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 5px 0;
      font-size: 13px;
      color: #444;
    }
    .totals-row.grand-total {
      border-top: 2px solid #1a1a1a;
      margin-top: 8px;
      padding-top: 10px;
      font-size: 16px;
      color: #1a1a1a;
      letter-spacing: 0.03em;
    }
    .totals-row.grand-total .t-label {
      text-transform: uppercase;
      letter-spacing: 0.12em;
      font-size: 11px;
    }
    .totals-row.grand-total .t-value {
      font-size: 18px;
    }
    .totals-row.change-row { color: #c9a96e; }
    .t-label { color: #888; font-size: 12px; }

    /* ── Payment badge ───────────────────────────────── */
    .payment-badge {
      display: inline-block;
      background: #1a1a1a;
      color: #c9a96e;
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 4px 10px;
      border-radius: 2px;
      margin-top: 14px;
    }

    /* ── CTA Button ──────────────────────────────────── */
    .cta-wrapper {
      text-align: center;
      margin: 28px 0 8px;
    }
    .cta-button {
      display: inline-block;
      background: #1a1a1a;
      color: #f4f1ec !important;
      text-decoration: none;
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 13px 28px;
      border-radius: 2px;
    }

    /* ── Divider ─────────────────────────────────────── */
    .divider {
      border: none;
      border-top: 1px dashed #d0c9bc;
      margin: 24px 0;
    }

    /* ── Footer ──────────────────────────────────────── */
    .footer {
      background: #f4f1ec;
      border-top: 1px solid #e0d9ce;
      padding: 24px 40px;
      text-align: center;
    }
    .footer-shop {
      font-size: 11px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #1a1a1a;
      margin-bottom: 8px;
    }
    .footer-contact {
      font-size: 11.5px;
      color: #777;
      line-height: 1.8;
    }
    .footer-contact a { color: #777; text-decoration: none; }
    .footer-legal {
      margin-top: 16px;
      font-size: 10.5px;
      color: #aaa;
      line-height: 1.7;
    }

    /* ── Responsive ──────────────────────────────────── */
    @media (max-width: 480px) {
      .body { padding: 24px 20px; }
      .header { padding: 28px 20px 24px; }
      .footer { padding: 20px; }
      .logo-text { font-size: 18px; }
    }
  </style>
</head>
<body>
<div class="wrapper">
  <div class="container">

    <!-- ═══════════ HEADER ═══════════ -->
    <div class="header">
      <% if (logoUrl) { %>
        <img src="<%= logoUrl %>" alt="<%= shopName %>" class="logo-img" />
      <% } else { %>
        <div class="logo-text"><%= shopName %></div>
      <% } %>
      <% if (shopTagline) { %>
        <div class="tagline"><%= shopTagline %></div>
      <% } %>
    </div>

    <div class="receipt-banner">✦ &nbsp; Official Receipt &nbsp; ✦</div>

    <!-- ═══════════ BODY ═══════════ -->
    <div class="body">

      <!-- Order meta -->
      <table class="meta-grid" cellspacing="0" cellpadding="0">
        <tr>
          <td class="meta-label">Order</td>
          <td class="meta-value"><strong><%= orderName %></strong></td>
        </tr>
        <tr>
          <td class="meta-label">Date</td>
          <td class="meta-value"><%= dateOrder %></td>
        </tr>
        <tr>
          <td class="meta-label">Served by</td>
          <td class="meta-value"><%= servedBy %></td>
        </tr>
        <% if (customerName) { %>
        <tr>
          <td class="meta-label">Customer</td>
          <td class="meta-value"><%= customerName %></td>
        </tr>
        <% } %>
        <tr>
          <td class="meta-label">Order type</td>
          <td class="meta-value"><%= orderType %></td>
        </tr>
      </table>

      <!-- Items -->
      <p class="section-heading">Items</p>
      <table class="items-table" cellspacing="0" cellpadding="0">
        <thead>
          <tr>
            <th style="width:36px;">Qty</th>
            <th>Item</th>
            <th style="width:72px; text-align:right;">Price</th>
            <th style="width:72px; text-align:right;">Total</th>
          </tr>
        </thead>
        <tbody>
          <% lines.forEach(function(line) { %>
          <tr>
            <td class="center" style="color:#888;"><%= line.qty %></td>
            <td>
              <div class="item-name"><%= line.name %></div>
              <% if (line.discount > 0) { %>
                <div class="item-discount">– <%= line.discount %>% discount</div>
              <% } %>
            </td>
            <td style="text-align:right; color:#555;">
              <%= line.priceUnit.toFixed(2) %>
            </td>
            <td style="text-align:right;">
              <%= line.priceTotal.toFixed(2) %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>

      <!-- Totals -->
      <div class="totals-block">
        <div class="totals-row">
          <span class="t-label">Subtotal</span>
          <span><%= subtotal.toFixed(2) %></span>
        </div>
        <div class="totals-row">
          <span class="t-label">Tax</span>
          <span><%= tax.toFixed(2) %></span>
        </div>
        <div class="totals-row grand-total">
          <span class="t-label">Total</span>
          <span class="t-value"><%= total.toFixed(2) %></span>
        </div>

        <hr class="divider" style="margin: 12px 0;" />

        <div class="totals-row">
          <span class="t-label">Amount Paid</span>
          <span><%= amountPaid.toFixed(2) %></span>
        </div>
        <% if (change > 0) { %>
        <div class="totals-row change-row">
          <span class="t-label">Change</span>
          <span>– <%= change.toFixed(2) %></span>
        </div>
        <% } %>

        <div>
          <span class="payment-badge"><%= paymentMethod %></span>
        </div>
      </div>

      <!-- CTA -->
      <% if (ticketUrl) { %>
      <div class="cta-wrapper">
        <a href="<%= ticketUrl %>" class="cta-button">View Full Receipt Online</a>
      </div>
      <% } %>

    </div><!-- /body -->

    <!-- ═══════════ FOOTER ═══════════ -->
    <div class="footer">
      <div class="footer-shop"><%= shopName %></div>
      <div class="footer-contact">
        <% if (shopAddress) { %><%= shopAddress %><br /><% } %>
        <% if (shopPhone) { %>
          <a href="tel:<%= shopPhone %>"><%= shopPhone %></a>
          <% if (shopEmail) { %> &nbsp;·&nbsp; <% } %>
        <% } %>
        <% if (shopEmail) { %>
          <a href="mailto:<%= shopEmail %>"><%= shopEmail %></a>
        <% } %>
      </div>
      <div class="footer-legal">
        This is an automated receipt. Please keep it for your records.<br />
        © <%= new Date().getFullYear() %> <%= shopName %>. All rights reserved.
      </div>
    </div>

  </div><!-- /container -->
</div><!-- /wrapper -->
</body>
</html>
