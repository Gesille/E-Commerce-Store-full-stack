<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Receipt - <%= receiptNo %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, Helvetica, sans-serif; background: #f4f4f4; padding: 24px; }

    .receipt-wrap {
      max-width: 520px;
      margin: 0 auto;
      background: #ffffff;
      border: 1px solid #d0d0d0;
      color: #111111;
      font-size: 13px;
    }

    /* ── HEADER ── */
    .receipt-header {
      border-bottom: 2px solid #111111;
      padding: 20px 24px 16px;
    }
    .shop-logo {
      max-height: 52px;
      margin-bottom: 8px;
      display: block;
    }
    .shop-name {
      font-size: 22px;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .shop-tagline {
      font-size: 10px;
      color: #666;
      margin-top: 3px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .shop-contact {
      font-size: 11.5px;
      color: #444;
      margin-top: 10px;
      line-height: 1.75;
    }

    /* ── META BAR ── */
    .meta-bar {
      background: #f7f7f7;
      border-bottom: 1px solid #d0d0d0;
      padding: 10px 24px;
      display: flex;
      flex-wrap: wrap;
      gap: 0;
    }
    .meta-item {
      display: flex;
      flex-direction: column;
      min-width: 100px;
      padding-right: 28px;
      margin-right: 28px;
      border-right: 1px solid #ddd;
      padding-top: 4px;
      padding-bottom: 4px;
    }
    .meta-item:last-child {
      border-right: none;
      margin-right: 0;
      padding-right: 0;
    }
    .meta-label {
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: #999;
      margin-bottom: 2px;
    }
    .meta-value {
      font-weight: 700;
      color: #111;
      font-size: 12.5px;
    }

    /* ── BILL TO ── */
    .bill-section {
      padding: 14px 24px 16px;
      border-bottom: 1px solid #d0d0d0;
    }
    .section-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.09em;
      text-transform: uppercase;
      color: #999;
      margin-bottom: 5px;
    }
    .bill-name {
      font-weight: 700;
      font-size: 13.5px;
      color: #111;
    }
    .bill-sub {
      font-size: 11.5px;
      color: #555;
      margin-top: 2px;
      line-height: 1.65;
    }
    .bill-abst {
      font-size: 11.5px;
      color: #444;
      margin-top: 6px;
    }
    .bill-abst strong {
      color: #111;
    }

    /* ── ITEMS TABLE ── */
    .items-area {
      border-bottom: 1px solid #d0d0d0;
    }
    .items-table {
      width: 100%;
      border-collapse: collapse;
    }
    .items-table thead tr {
      background: #ebebeb;
      border-bottom: 1px solid #d0d0d0;
    }
    .items-table th {
      padding: 6px 24px;
      font-size: 9.5px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: #555;
      text-align: left;
    }
    .items-table th.right,
    .items-table td.right { text-align: right; }
    .items-table td {
      padding: 9px 24px;
      font-size: 12.5px;
      border-bottom: 1px solid #f0f0f0;
      color: #111;
      vertical-align: top;
    }
    .items-table tbody tr:last-child td { border-bottom: none; }
    .discount-line td { color: #777; font-size: 11.5px; font-style: italic; }

    /* ── TOTALS ── */
    .totals-section {
      border-top: 2px solid #111;
    }
    .totals-table {
      width: 100%;
      border-collapse: collapse;
    }
    .totals-table td {
      padding: 6px 24px;
      font-size: 12.5px;
      color: #111;
    }
    .totals-table td:last-child { text-align: right; }

    .row-subtotal td { padding-top: 10px; }
    .row-tax td { color: #555; }

    .row-total {
      border-top: 2px solid #111;
    }
    .row-total td {
      padding: 10px 24px;
      font-size: 16px;
      font-weight: 700;
    }

    .row-paid {
      background: #f5f5f5;
      border-top: 1px solid #d0d0d0;
    }
    .row-paid td { padding: 7px 24px; font-size: 12.5px; color: #333; }

    .row-change {
      background: #f5f5f5;
    }
    .row-change td {
      padding: 6px 24px 10px;
      font-size: 12.5px;
      color: #059669;
      font-weight: 600;
    }

    .payment-badge {
      display: inline-block;
      background: #111;
      color: #fff;
      padding: 2px 7px;
      font-size: 9.5px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-left: 6px;
      vertical-align: middle;
    }

    /* ── POLICY STRIP ── */
    .policy-strip {
      padding: 16px 24px;
      text-align: center;
      font-size: 12px;
      border-top: 1px solid #e5e5e5;
      color: #555;
      line-height: 1.7;
    }
    .policy-strip a {
      color: #2563eb;
      text-decoration: none;
      font-weight: 600;
    }

    /* ── FOOTER ── */
    .footer-strip {
      background: #111;
      color: #fff;
      text-align: center;
      padding: 11px 24px;
      font-size: 10px;
      letter-spacing: 0.09em;
      text-transform: uppercase;
    }
  </style>
</head>
<body>
  <div class="receipt-wrap">

    <!-- HEADER -->
    <div class="receipt-header">
      <% if (logoUrl) { %>
        <img class="shop-logo" src="<%= logoUrl %>" alt="<%= shopName %>" />
      <% } %>
      <div class="shop-name"><%= shopName %></div>
      <% if (shopTagline) { %>
        <div class="shop-tagline"><%= shopTagline %></div>
      <% } %>
      <div class="shop-contact">
        Phone # <%= shopPhone %><br>
        <% if (shopEmail) { %><%= shopEmail %><br><% } %>
        ABST # <%= shopABST %><br>
        <% if (shopAddress) { %><%= shopAddress %><% } %>
      </div>
    </div>

    <!-- META BAR -->
    <div class="meta-bar">
      <div class="meta-item">
        <span class="meta-label">Receipt No</span>
        <span class="meta-value"><%= receiptNo %></span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Date</span>
        <span class="meta-value"><%= date %></span>
      </div>
      <% if (odooOrderId) { %>
      <div class="meta-item">
        <span class="meta-label">Order ID</span>
        <span class="meta-value">#<%= odooOrderId %></span>
      </div>
      <% } %>
    </div>

    <!-- BILL TO -->
    <% if (customerName) { %>
    <div class="bill-section">
      <div class="section-label">Bill To</div>
      <div class="bill-name"><%= customerName %></div>
      <% if (customerAddress) { %>
        <div class="bill-sub"><%= customerAddress %></div>
      <% } %>
      <% if (customerAbst) { %>
        <div class="bill-abst">Cust ABST # &nbsp;<strong><%= customerAbst %></strong></div>
      <% } %>
    </div>
    <% } %>

    <!-- ITEMS -->
    <div class="items-area">
      <table class="items-table">
        <thead>
          <tr>
            <th style="width:46px;">Qty</th>
            <th>Description</th>
            <th class="right" style="width:100px;">Price Each</th>
            <th class="right" style="width:108px;">Amount</th>
          </tr>
        </thead>
        <tbody>
          <% lines.forEach(function(line) { %>
            <tr>
              <td><%= line.qty %></td>
              <td><%= line.name %></td>
              <td class="right">$<%= line.priceUnit.toFixed(2) %></td>
              <td class="right">$<%= line.priceTotal.toFixed(2) %></td>
            </tr>
            <% if (line.discount > 0) { %>
            <tr class="discount-line">
              <td></td>
              <td>Discount (<%= line.discount %>%)</td>
              <td class="right"></td>
              <td class="right" style="color:#dc2626;">-$<%= (line.priceUnit * line.qty * line.discount / 100).toFixed(2) %></td>
            </tr>
            <% } %>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- TOTALS -->
    <div class="totals-section">
      <table class="totals-table">
        <tr class="row-subtotal">
          <td>Subtotal</td>
          <td>$<%= subtotal.toFixed(2) %></td>
        </tr>
        <tr class="row-tax">
          <td>Tax (17%)</td>
          <td>$<%= tax.toFixed(2) %></td>
        </tr>
        <tr class="row-total">
          <td>Total</td>
          <td>$<%= total.toFixed(2) %></td>
        </tr>
        <% paymentLines.forEach(function(p) { %>
        <tr class="row-paid">
          <td>
            <span style="text-transform:capitalize;"><%= p.method %></span>
            <span class="payment-badge"><%= p.method %></span>
          </td>
          <td>$<%= p.amount.toFixed(2) %></td>
        </tr>
        <% }); %>
        <% if (change > 0.005) { %>
        <tr class="row-change">
          <td>Change</td>
          <td>$<%= change.toFixed(2) %></td>
        </tr>
        <% } %>
      </table>
    </div>

    <!-- POLICY -->
    <% if (policyUrl) { %>
    <div class="policy-strip">
      View our store policies:<br>
      <a href="<%= policyUrl %>" target="_blank">Return Policy &amp; Terms</a>
    </div>
    <% } %>

    <!-- FOOTER -->
    <div class="footer-strip">
      Thank you for your purchase &nbsp;&middot;&nbsp; <%= shopName %>
    </div>

  </div>
</body>
</html>
