<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Receipt - <%= receiptNo %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: Arial, Helvetica, sans-serif; background: #f4f4f4; padding: 24px; }

    .receipt-wrap {
      max-width: 480px;
      margin: 0 auto;
      background: #ffffff;
      border: 1px solid #222222;
      color: #111111;
      font-size: 13px;
    }

    .receipt-header {
      border-bottom: 2px solid #111111;
      padding: 16px 20px 14px;
    }
    .shop-name { font-size: 20px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; }
    .shop-tagline { font-size: 10px; color: #555; margin-top: 3px; letter-spacing: 0.05em; text-transform: uppercase; }
    .shop-contact { font-size: 11px; color: #444; margin-top: 8px; line-height: 1.7; }

    .meta-bar {
      background: #f7f7f7;
      border-bottom: 1px solid #bbb;
      padding: 10px 20px;
      font-size: 11px;
      display: flex;
      gap: 24px;
      flex-wrap: wrap;
    }
    .meta-item { display: flex; flex-direction: column; }
    .meta-label { font-size: 9px; text-transform: uppercase; letter-spacing: 0.08em; color: #888; margin-bottom: 1px; }
    .meta-value { font-weight: 700; color: #111; font-size: 12px; }

    .bill-row { display: flex; border-bottom: 1px solid #bbb; }
    .bill-section { flex: 1; padding: 12px 20px; font-size: 12px; line-height: 1.7; border-right: 1px solid #bbb; }
    .bill-section:last-child { border-right: none; }
    .section-label { font-size: 9px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: #888; margin-bottom: 5px; }
    .bill-name { font-weight: 700; font-size: 13px; color: #111; }

    .items-area { border-bottom: 1px solid #bbb; }
    .items-table { width: 100%; border-collapse: collapse; }
    .items-table thead tr { background: #e0e0e0; border-bottom: 1px solid #bbb; }
    .items-table th { padding: 5px 20px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; text-align: left; }
    .items-table th.right, .items-table td.right { text-align: right; }
    .items-table td { padding: 7px 20px; font-size: 12px; border-bottom: 1px solid #eee; color: #111; }
    .items-table tbody tr:last-child td { border-bottom: none; }
    .discount-line td { color: #555; font-style: italic; }

    .totals-section { border-top: 2px solid #111; }
    .totals-table { width: 100%; border-collapse: collapse; }
    .totals-table td { padding: 5px 20px; font-size: 12px; color: #111; }
    .totals-table td:last-child { text-align: right; }
    .totals-table .row-subtotal td { padding-top: 9px; }
    .totals-table .row-tax td { color: #444; }
    .totals-table .row-total { border-top: 2px solid #111; }
    .totals-table .row-total td { padding: 10px 20px; font-size: 16px; font-weight: 700; }
    .totals-table .row-paid { background: #f0f0f0; border-top: 1px solid #bbb; }
    .totals-table .row-paid td { padding: 6px 20px; font-size: 12px; color: #333; }
    .totals-table .row-change td { padding: 5px 20px 9px; font-size: 12px; color: #059669; background: #f0f0f0; font-weight: 600; }

    .payment-badge {
      display: inline-block;
      background: #111;
      color: #fff;
      padding: 2px 8px;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      margin-left: 6px;
    }

    .footer-strip {
      background: #111;
      color: #fff;
      text-align: center;
      padding: 10px 20px;
      font-size: 10px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
  </style>
</head>
<body>
  <div class="receipt-wrap">

    <!-- HEADER -->
    <div class="receipt-header">
      <% if (logoUrl) { %>
        <img src="<%= logoUrl %>" alt="<%= shopName %>" style="max-height: 48px; margin-bottom: 6px; display: block;" />
      <% } %>
      <div class="shop-name"><%= shopName %></div>
      <% if (shopTagline) { %>
        <div class="shop-tagline"><%= shopTagline %></div>
      <% } %>
      <div class="shop-contact">
        Phone # <%= shopPhone %><br>
        <% if (shopEmail) { %><%= shopEmail %><br><% } %>
        ABST # <%= shopABST %><br>
        <% if (shopAddress) { %><%= shopAddress %><% } %>
      </div>
    </div>

    <!-- META BAR -->
    <div class="meta-bar">
      <div class="meta-item">
        <span class="meta-label">Receipt No</span>
        <span class="meta-value"><%= receiptNo %></span>
      </div>
      <div class="meta-item">
        <span class="meta-label">Date</span>
        <span class="meta-value"><%= date %></span>
      </div>
      <% if (odooOrderId) { %>
      <div class="meta-item">
        <span class="meta-label">Order ID</span>
        <span class="meta-value">#<%= odooOrderId %></span>
      </div>
      <% } %>
    </div>

    <!-- BILL TO -->
    <div class="bill-row">
      <div class="bill-section">
        <div class="section-label">Bill To</div>
        <% if (customerName) { %>
          <div class="bill-name"><%= customerName %></div>
        <% } else { %>
          <div style="color: #999; font-size: 12px;">Walk-in Customer</div>
        <% } %>
      </div>
    </div>

    <!-- ITEMS -->
    <div class="items-area">
      <table class="items-table">
        <thead>
          <tr>
            <th style="width: 44px;">Qty</th>
            <th>Description</th>
            <th class="right" style="width: 90px;">Price Each</th>
            <th class="right" style="width: 100px;">Amount</th>
          </tr>
        </thead>
        <tbody>
          <% lines.forEach(function(line) { %>
            <tr>
              <td><%= line.qty %></td>
              <td><%= line.name %></td>
              <td class="right">$<%= line.priceUnit.toFixed(2) %></td>
              <td class="right">$<%= line.priceTotal.toFixed(2) %></td>
            </tr>
            <% if (line.discount > 0) { %>
            <tr class="discount-line">
              <td></td>
              <td>Discount (<%= line.discount %>%)</td>
              <td class="right"></td>
              <td class="right" style="color: #dc2626;">-$<%= (line.priceUnit * line.qty * line.discount / 100).toFixed(2) %></td>
            </tr>
            <% } %>
          <% }); %>
        </tbody>
      </table>
    </div>

    <!-- TOTALS -->
    <div class="totals-section">
      <table class="totals-table">
        <tr class="row-subtotal">
          <td>Subtotal</td>
          <td>$<%= subtotal.toFixed(2) %></td>
        </tr>
        <tr class="row-tax">
          <td>Tax (17%)</td>
          <td>$<%= tax.toFixed(2) %></td>
        </tr>
        <tr class="row-total">
          <td>Total</td>
          <td>$<%= total.toFixed(2) %></td>
        </tr>
        <% paymentLines.forEach(function(p) { %>
        <tr class="row-paid">
          <td>
            <span style="text-transform: capitalize;"><%= p.method %></span>
            <span class="payment-badge"><%= p.method %></span>
          </td>
          <td>$<%= p.amount.toFixed(2) %></td>
        </tr>
        <% }); %>
        <% if (change > 0.005) { %>
        <tr class="row-change">
          <td>Change</td>
          <td>$<%= change.toFixed(2) %></td>
        </tr>
        <% } %>
      </table>
    </div>
<div style="
  padding:18px 20px;
  text-align:center;
  font-size:12px;
  border-top:1px solid #ddd;
">

  <p style="margin-bottom:8px;">
    View our store policies:
  </p>

  <a 
    href="<%= policyUrl %>"
    target="_blank"
    style="
      color:#2563eb;
      text-decoration:none;
      font-weight:600;
    "
  >
    Return Policy & Terms
  </a>

</div>
    <!-- FOOTER -->
    <div class="footer-strip">
      Thank you for your purchase &nbsp;&middot;&nbsp; <%= shopName %>
    </div>

  </div>
</body>
</html>