<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Welcome to ShopStore</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #f0f4ff;
      padding: 40px 20px;
    }

    .wrapper {
      max-width: 580px;
      margin: 0 auto;
    }

    .card {
      background: #ffffff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(99, 102, 241, 0.12);
    }

    /* Header */
    .header {
      background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 50%, #2563eb 100%);
      padding: 40px 32px;
      text-align: center;
    }

    .header .logo {
      font-size: 28px;
      font-weight: 800;
      color: #ffffff;
      letter-spacing: -0.5px;
    }

    .header .logo span {
      color: #a5b4fc;
    }

    .header .tagline {
      color: #c7d2fe;
      font-size: 13px;
      margin-top: 6px;
    }

    /* Welcome banner */
    .banner {
      background: linear-gradient(135deg, #eef2ff, #f5f3ff);
      padding: 32px;
      text-align: center;
      border-bottom: 1px solid #e0e7ff;
    }

    .banner .icon {
      width: 64px;
      height: 64px;
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      margin-bottom: 16px;
    }

    .banner h1 {
      font-size: 22px;
      font-weight: 700;
      color: #1e1b4b;
      margin-bottom: 8px;
    }

    .banner p {
      font-size: 14px;
      color: #6b7280;
      line-height: 1.6;
    }

    /* Body */
    .body {
      padding: 32px;
    }

    .body .intro {
      font-size: 14px;
      color: #374151;
      line-height: 1.7;
      margin-bottom: 24px;
    }

    /* Credentials box */
    .credentials {
      background: #f8faff;
      border: 1px solid #e0e7ff;
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 24px;
    }

    .credentials .cred-header {
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      padding: 12px 20px;
      font-size: 12px;
      font-weight: 600;
      color: #ffffff;
      text-transform: uppercase;
      letter-spacing: 0.8px;
    }

    .credentials .cred-row {
      display: flex;
      align-items: center;
      padding: 14px 20px;
      border-bottom: 1px solid #e0e7ff;
      gap: 12px;
    }

    .credentials .cred-row:last-child {
      border-bottom: none;
    }

    .credentials .cred-icon {
      width: 32px;
      height: 32px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      flex-shrink: 0;
    }

    .cred-icon.email-icon { background: #ede9fe; }
    .cred-icon.pass-icon  { background: #fce7f3; }

    .credentials .cred-label {
      font-size: 11px;
      color: #9ca3af;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 2px;
    }

    .credentials .cred-value {
      font-size: 14px;
      font-weight: 600;
      color: #1f2937;
      word-break: break-all;
    }

    /* Warning box */
    .warning {
      background: #fffbeb;
      border: 1px solid #fde68a;
      border-left: 4px solid #f59e0b;
      border-radius: 8px;
      padding: 14px 16px;
      display: flex;
      gap: 10px;
      align-items: flex-start;
      margin-bottom: 28px;
    }

    .warning .warn-icon { font-size: 18px; flex-shrink: 0; }

    .warning p {
      font-size: 13px;
      color: #92400e;
      line-height: 1.5;
    }

    /* CTA Button */
    .cta {
      text-align: center;
      margin-bottom: 28px;
    }

    .cta a {
      display: inline-block;
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      color: #ffffff;
      text-decoration: none;
      font-size: 15px;
      font-weight: 600;
      padding: 14px 40px;
      border-radius: 10px;
      letter-spacing: 0.3px;
      box-shadow: 0 4px 14px rgba(79, 70, 229, 0.35);
    }

    /* Divider */
    .divider {
      border: none;
      border-top: 1px solid #e5e7eb;
      margin: 0 0 24px;
    }

    /* Help section */
    .help {
      text-align: center;
      font-size: 13px;
      color: #6b7280;
      line-height: 1.6;
    }

    .help a {
      color: #4f46e5;
      text-decoration: none;
      font-weight: 500;
    }

    /* Footer */
    .footer {
      background: #f9fafb;
      border-top: 1px solid #e5e7eb;
      padding: 24px 32px;
      text-align: center;
    }

    .footer p {
      font-size: 12px;
      color: #9ca3af;
      line-height: 1.6;
    }

    .footer .social {
      margin-top: 12px;
      display: flex;
      justify-content: center;
      gap: 12px;
    }

    .footer .social a {
      width: 32px;
      height: 32px;
      background: #e0e7ff;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="card">

      <!-- Header -->
      <div class="header">
        <div class="logo">Shop<span>Store</span></div>
        <div class="tagline">Your trusted equipment marketplace</div>
      </div>

      <!-- Banner -->
      <div class="banner">
        <div class="icon">👋</div>
        <h1>Welcome aboard, <%= name %>!</h1>
        <p>Your account has been set up and is ready to use.<br/>Here are your login credentials.</p>
      </div>

      <!-- Body -->
      <div class="body">
        <p class="intro">
          Hi <strong><%= name %></strong>, our team has created an account for you on ShopStore.
          You can now browse our full catalog and place orders. Use the credentials below to log in.
        </p>

        <!-- Credentials -->
        <div class="credentials">
          <div class="cred-header">🔐 Your Login Credentials</div>

          <div class="cred-row">
            <div class="cred-icon email-icon">📧</div>
            <div>
              <div class="cred-label">Email Address</div>
              <div class="cred-value"><%= email %></div>
            </div>
          </div>

          <div class="cred-row">
            <div class="cred-icon pass-icon">🔑</div>
            <div>
              <div class="cred-label">Temporary Password</div>
              <div class="cred-value"><%= password %></div>
            </div>
          </div>
        </div>

        <!-- Warning -->
        <div class="warning">
          <div class="warn-icon">⚠️</div>
          <p>For your security, please <strong>change your password</strong> immediately after your first login. Do not share these credentials with anyone.</p>
        </div>

        <!-- CTA -->
        <div class="cta">
          <a href="<%= process.env.FRONTEND_URL %>">Log In to Your Account →</a>
        </div>

        <hr class="divider" />

        <!-- Help -->
        <div class="help">
          Need help? Contact our support team at
          <a href="mailto:<%= process.env.SUPPORT_EMAIL %>"><%= process.env.SUPPORT_EMAIL %></a>
          <br/>or reply directly to this email.
        </div>
      </div>

      <!-- Footer -->
      <div class="footer">
        <p>© <%= new Date().getFullYear() %> ShopStore. All rights reserved.<br/>
        You received this email because an account was created for you.</p>
        <div class="social">
          <a href="#">🐦</a>
          <a href="#">💼</a>
          <a href="#">📘</a>
        </div>
      </div>

    </div>
  </div>
</body>
</html>